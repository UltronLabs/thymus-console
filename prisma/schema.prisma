// Thymus console — decision store + tenancy.
//
// Tenancy model: `tenantId` is a Clerk org id ("org_...") when the acting user
// has an active organization, or a Clerk user id ("user_...") for a personal
// account. Both shapes are opaque strings from Clerk — no separate Tenant
// table needed; User/ApiKey/Decision all key off the same string.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Synced from Clerk via webhook (user.created / user.updated / user.deleted).
// Not used for auth (Clerk remains the source of truth) — this is a local
// mirror for joins, display, and anything we want to query without calling
// the Clerk Backend API on every request.
model User {
  id        String   @id // Clerk user id ("user_...")
  email     String?
  firstName String?
  lastName  String?
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Synced from Clerk via webhook (organization.created / .updated / .deleted).
model Organization {
  id        String   @id // Clerk org id ("org_...")
  name      String
  slug      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Per-tenant ingest key for the SDK's HttpAuditSink (replaces the single
// global THYMUS_API_KEY). One active key per tenant is typical; history is
// kept (revoked, not deleted) for audit continuity.
model ApiKey {
  id         String    @id @default(cuid())
  tenantId   String // org id or personal user id
  // Store only a hash; the raw key is shown once at creation time.
  keyHash    String    @unique
  keyPrefix  String // first chars shown in the UI, e.g. "thym_ab12"
  createdAt  DateTime  @default(now())
  createdBy  String? // Clerk user id of whoever generated it
  revokedAt  DateTime?

  @@index([tenantId])
}

// Per-tenant tuning of the SDK's TrustPolicy — the *working* (draft) copy that
// the Settings UI edits. This is NOT what the SDK reads directly: the SDK fetches
// the active PolicyVersion snapshot (see below), so edits here only reach agents
// once published. Full editor: thresholds, per-tier base trust, floor severity,
// which detectors run, which built-in rules are off, and custom rules (see
// CustomRule).
model TenantPolicy {
  tenantId         String   @id
  quarantineBelow  Float    @default(0.45)
  tagBelow         Float    @default(0.70)
  enabledDetectors String   @default("[\"origin\",\"injection\",\"egress\",\"conflict\",\"rules\"]") // JSON array
  // Per-tier starting trust before detectors run; JSON {trusted,standard,untrusted,hostile}.
  baseTrust        String   @default("{\"trusted\":0.95,\"standard\":0.8,\"untrusted\":0.5,\"hostile\":0.2}")
  // Min severity that forces at least a TAG from an attacker-reachable origin.
  floorSeverity    String   @default("high") // none | low | medium | high | critical
  // Built-in rule ids the tenant has switched off; JSON array of strings.
  disabledRuleIds  String   @default("[]")
  // Which PolicyVersion the SDK currently serves (null = nothing published yet).
  activeVersion    Int?
  updatedAt        DateTime @updatedAt
}

// A tenant-authored detection rule (co-occurrence of term groups), mirroring the
// SDK's rule-pack format so remote_engine can build a RuleDetector from it. Lives
// in the working set; a snapshot is frozen into each PolicyVersion on publish.
model CustomRule {
  id          String   @id @default(cuid())
  tenantId    String
  ruleId      String // stable slug, e.g. "custom.refund_override"
  description String   @default("")
  severity    String   @default("medium") // none | low | medium | high | critical
  trustDelta  Float    @default(-0.4)
  flags       String   @default("[]") // JSON array of flag strings
  allOf       String   @default("[]") // JSON array of groups; each group a JSON array of patterns
  tags        String   @default("[]") // JSON array
  enabled     Boolean  @default(true)
  createdBy   String? // Clerk user id
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, ruleId])
  @@index([tenantId])
}

// An immutable, published snapshot of a tenant's entire compiled policy (the same
// JSON shape GET /api/policy returns). Append-only history: publishing creates a
// new row + points TenantPolicy.activeVersion at it; rollback re-publishes an old
// snapshot as a new version, so history is never rewritten.
model PolicyVersion {
  id        String   @id @default(cuid())
  tenantId  String
  version   Int // per-tenant incrementing number
  snapshot  String // JSON: the full CompiledPolicy served to SDKs
  note      String   @default("")
  createdBy String? // Clerk user id
  createdAt DateTime @default(now())

  @@unique([tenantId, version])
  @@index([tenantId, version])
}

model Decision {
  id              String    @id @default(cuid())
  tenantId        String    @default("default") // Clerk org id or user id

  agentId         String?
  sessionId       String?
  actorId         String?
  channel         String // user_chat | tool_output | web | rag_doc | system | agent | unknown
  originTrustTier String // trusted | standard | untrusted | hostile

  text            String? // the memory text (may be omitted/redacted)
  contentHash     String?

  verdict         String // admit | tag | quarantine
  trustScore      Float
  severity        String // none | low | medium | high | critical
  taintFlags      String  @default("[]") // JSON array of flag strings
  reason          String?
  decidingPolicy  String?

  // Review lifecycle (only meaningful for quarantined rows).
  reviewStatus    String    @default("none") // none | pending | released | deleted | marked_safe
  reviewedAt      DateTime?
  reviewer        String?
  reviewNote      String?

  createdAt       DateTime  @default(now())

  @@index([tenantId, verdict])
  @@index([tenantId, createdAt])
  @@index([tenantId, reviewStatus])
}
